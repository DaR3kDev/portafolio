---
import { Image } from "astro:assets"
import { Menu, X } from "@lucide/astro"

import Logo from "~/assets/image/logo.webp"
import ToggleDarkMode from "~/components/toggle/ToggleDarkMode.astro"
import ToggleLenguajes from "~/components/toggle/ToggleLenguajes.astro"
import { getLangFromUrl, getTranslatedPath, getTranslations } from "~/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
const translatePath = getTranslatedPath(lang)

const navbarItems = [
	{ name: t("nav.home"), href: "#hero" },
	{ name: t("nav.experience"), href: "#experience" },
	{ name: t("nav.projects"), href: "#projects" },
	{ name: t("nav.education"), href: "#education" },
	{ name: t("nav.about"), href: "#about" },
	{ name: t("nav.contact"), href: "mailto:kevinvilleperez@gmail.com" },
]
---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50
  bg-white/5 dark:bg-black/20
  backdrop-blur-md
  border-b border-white/10
  transition-all duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center shrink-0">
        <Image src={Logo} alt="Logo" class="h-10 w-10 rounded-full object-cover" />
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex flex-1 justify-center gap-8">
        {
          navbarItems.map(item => (
            <a
              href={translatePath(item.href)}
              class="nav-link text-sm font-medium text-gray-300 hover:text-white transition-colors duration-300"
            >
              {item.name}
            </a>
          ))
        }
      </div>

      <!-- Right Controls -->
      <div class="flex items-center gap-3">
        <ToggleLenguajes />
        <ToggleDarkMode />

        <!-- Mobile Button -->
        <button
          id="menu-btn"
          class="md:hidden text-gray-300 hover:text-white transition"
          aria-label="Toggle Menu"
        >
          <Menu id="icon-open" class="w-6 h-6" />
          <X id="icon-close" class="w-6 h-6 hidden" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden
    bg-white/90 dark:bg-neutral-950/90
    backdrop-blur-md
    border-t border-black/10 dark:border-white/10"
  >
    <div class="px-6 py-6 flex flex-col gap-6 text-center">
      {
        navbarItems.map(item => (
          <a
            href={item.href}
            class="mobile-link nav-link text-base font-medium text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors duration-300"
          >
            {item.name}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script is:inline>
  /* MENU MOBILE */

  const menuBtn = document.getElementById('menu-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden')
    iconOpen?.classList.toggle('hidden')
    iconClose?.classList.toggle('hidden')
  })

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden')
      iconOpen?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
    })
  })

  /* NAVBAR SCROLL EFFECT */

  const navbar = document.getElementById('navbar')

  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar.classList.add('bg-white/80', 'dark:bg-neutral-950/80', 'shadow-md')
    } else {
      navbar.classList.remove('bg-white/80', 'dark:bg-neutral-950/80', 'shadow-md')
    }
  })

  const sections = document.querySelectorAll('section')
  const navLinks = document.querySelectorAll('.nav-link')

  window.addEventListener('scroll', () => {
    let current = ''

    sections.forEach(section => {
      const sectionTop = section.offsetTop
      const sectionHeight = section.clientHeight

      if (scrollY >= sectionTop - 200) current = section.getAttribute('id')
    })

    navLinks.forEach(link => {
      link.classList.remove('text-white')

      if (link.getAttribute('href') === '#' + current) link.classList.add('text-white')
    })
  })
</script>
