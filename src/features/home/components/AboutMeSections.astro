---
import { Image } from "astro:assets"
import { MapPin } from "@lucide/astro"
import Logo from "~/assets/image/me.webp"
import { getPageData } from "~/utils/getBlogPage"

const data = await getPageData(Astro.url, "aboutme")
---

<section id="about" class="py-16 sm:py-20 lg:py-32 px-4 sm:px-6 lg:px-8">
  <!-- Title -->
  <div class="max-w-3xl mx-auto text-center space-y-4">
    <h2
      class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white"
    >
      {data.title}
    </h2>
  </div>

  <div class="mt-12 sm:mt-16 grid gap-12 lg:gap-20 lg:grid-cols-2 items-center">
    <div class="space-y-10 text-center lg:text-left">
      <div class="space-y-6 text-gray-900 dark:text-white">
        <p class="text-base sm:text-lg leading-relaxed">
          {data.description1}
        </p>

        <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm sm:text-base">
          {data.description2}
        </p>
      </div>

      <!-- Info cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-md mx-auto lg:mx-0">
        <div
          class="flex items-center gap-4 p-5 rounded-2xl bg-gray-100 dark:bg-neutral-900 border border-gray-200 dark:border-gray-800"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-xl bg-gray-200 dark:bg-neutral-800"
          >
            <MapPin class="w-6 h-6 text-gray-700 dark:text-gray-300" />
          </div>

          <div class="text-left">
            <h4 class="font-semibold text-gray-900 dark:text-white">
              {data.locationLabel}
            </h4>

            <p class="text-sm text-gray-600 dark:text-gray-400">
              {data.location}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Image -->
    <div class="flex justify-center lg:justify-end">
      <div
        class="relative w-52 h-52 sm:w-64 sm:h-64 md:w-72 md:h-72 lg:w-80 lg:h-80 xl:w-96 xl:h-96 rounded-full overflow-hidden shadow-xl border border-gray-200 dark:border-gray-800 hover:scale-105 transition duration-300"
      >
        <Image src={Logo} alt="Foto personal" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>
</section>
